SPRING_PROFILES_ACTIVE=prod
FANFLOW_SERVER_PORT=8096
FANFLOW_DB_URL=jdbc:mysql://localhost:3306/fanflow?serverTimezone=Asia/Seoul&characterEncoding=UTF-8
FANFLOW_DB_USERNAME=your_db_user
FANFLOW_DB_PASSWORD=your_db_password
FANFLOW_JWT_SECRET=your_jwt_secret
FANFLOW_JWT_EXPIRATION=1800000
FANFLOW_FILE_UPLOAD_DIR=/home/ubuntu/fanflow/uploads
FANFLOW_CORS_ALLOWED_ORIGINS=https://fanflow.example.com